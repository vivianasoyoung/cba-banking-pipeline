# Copy to .env and edit. Never commit .env.
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cba_pipeline

AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=change_me

# Airflow Connection injected into the scheduler/worker as env var.
# Matches POSTGRES_CONN_ID = "cba_postgres" in the DAG.
AIRFLOW_CONN_CBA_POSTGRES=postgresql://airflow:change_me@postgres:5432/cba_pipeline

# dbt
DBT_PROJECT_DIR=/opt/airflow/dbt
DBT_PROFILES_DIR=/opt/airflow/dbt
